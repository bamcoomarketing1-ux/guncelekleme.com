# ============================================================
#  RAILWAY ORTAM DEĞİŞKENLERİ
#  Bu dosyayı yüklemeyin. İçindeki değerleri Railway panelinde
#  "Variables" sekmesine tek tek girin (veya Raw Editor ile yapıştırın).
# ============================================================

APP_NAME=Alisulasyon
APP_ENV=production
APP_DEBUG=false

# ÖNEMLİ: Sabit bir anahtar kullanın. Yereldeki .env'de zaten bir tane var,
# onu buraya kopyalayabilirsiniz. Değiştirmeyin (oturumlar/şifrelemeler bozulur).
APP_KEY=base64:E24fi1VTk5BM7TI2ZFpFx5EJOKnW/ro1R+Y9k5xrb7E=

# Railway domain'inizi deploy sonrası buraya yazın (Settings > Domains)
APP_URL=https://SENIN-PROJEN.up.railway.app

# ---------- Veritabanı (Railway MySQL eklentisi) ----------
# Railway'de "New > Database > MySQL" ekledikten sonra en kolay yöntem:
# DB_URL değişkenini MySQL servisinin referansına bağlayın.
DB_CONNECTION=mysql
DB_URL=${{MySQL.MYSQL_URL}}

# Alternatif (DB_URL yerine tek tek referans):
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_DATABASE=${{MySQL.MYSQLDATABASE}}
# DB_USERNAME=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# ---------- Oturum / Kuyruk / Cache (DB tabanlı, ek servis gerekmez) ----------
QUEUE_CONNECTION=database
SESSION_DRIVER=database
CACHE_STORE=database

# ---------- Mail ----------
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME=${APP_NAME}

# ---------- Uygulamaya özel ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

XP_SYSTEM_ENABLED=true
MINES_DAILY_PLAYS=100
DICE_DAILY_PLAYS=100
SCRATCH_DAILY_PLAYS=5
